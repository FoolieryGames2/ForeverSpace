	"station_arrival_checkin": {
	  "objective_text": "Human Station Habitat reached. Docking channel opened.",
	  "interaction_type": "story_popup",
	  "next_step": "melissa_missed_checkin",
	  "on_enter": [
		{
		  "op": "show_story_popup",
		  "title": "HUMAN STATION HABITAT",
		  "text": "[b]STATION RELAY[/b]\n\n\"Hank, docking channel open.\"\n\n\"Where have you been?\"\n\n---\n\n[b]HANK[/b]\n\n\"Long story.\"\n\n\"Got a guest.\"\n\n---\n\n[b]STATION RELAY[/b]\n\n\"You don't bring guests.\"\n\n---\n\n[b]HANK[/b]\n\n\"I know.\"",
		  "images": [
			{
			  "path": "res://images/Hank.png"
			}
		  ],
		  "popup_size": {
			"x": 720,
			"y": 560
		  },
		  "close_mode": "button",
		  "next_step_on_close": "melissa_missed_checkin"
		}
	  ]
	},
	"melissa_missed_checkin": {
	  "objective_text": "Melissa missed her check-in.",
	  "interaction_type": "story_popup",
	  "next_step": "hank_grumbles_and_requests_help",
	  "on_enter": [
		{
		  "op": "show_story_popup",
		  "title": "STATION RELAY",
		  "text": "[b]STATION RELAY[/b]\n\n\"Hank...\"\n\n\"Melissa missed her check-in.\"\n\n\"Her beacon is still active, but she never made dock cycle.\"\n\n\"Last ping is holding near the outer belt.\"",
		  "popup_size": {
			"x": 720,
			"y": 520
		  },
		  "close_mode": "button",
		  "next_step_on_close": "hank_grumbles_and_requests_help"
		}
	  ]
	},
	"hank_grumbles_and_requests_help": {
	  "objective_text": "Hank asks for help reaching Melissa's beacon.",
	  "interaction_type": "story_popup",
	  "next_step": "tom_accepts_help",
	  "on_enter": [
		{
		  "op": "show_story_popup",
		  "title": "AUDIO POPUP",
		  "text": "[b]SOURCE:[/b] HANK\n[b]SIGNAL QUALITY:[/b] CLEAR\n\n\"Melissa.\"\n\n\"Girl's gonna be the death of me.\"\n\n\"She does this. Pushes too far, swears she has it handled, then makes everyone else sweat over the silence.\"\n\n\"I was going to help sort out your memory problems first, but that plan has to wait.\"\n\n\"Your warp signature is stronger than mine. A lot stronger.\"\n\n\"If her beacon is active, you can get there faster than I can.\"\n\n\"I hate asking this after dragging you here half-awake, but I need your help.\"",
		  "images": [
			{
			  "path": "res://images/Hank.png"
			}
		  ],
		  "popup_size": {
			"x": 720,
			"y": 580
		  },
		  "close_mode": "button",
		  "next_step_on_close": "tom_accepts_help"
		}
	  ]
	},
