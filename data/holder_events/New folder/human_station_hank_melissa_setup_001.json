		{
		  "op": "show_story_popup",
		  "title": "PLAYER RESPONSE",
		  "text": "I don't understand all of this.\n\nBut someone needs help.\n\nSo I will help.",
		  "images": [
			{
			  "path": "res://images/Tom.png"
			}
		  ],
