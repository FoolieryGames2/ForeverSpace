      ],
      "actions": [
        {
          "button_id": "ch4_confirm_waste_scout_sweep",
          "label": "CONFIRM SWEEP",
          "action_id": "event_operations",
          "target_object_id": "ch4_signal_scar_beacon_001",
          "range": 180,
          "requires_position_gate": true,
          "blocked_message": "Scout sweep incomplete. Defeat three Vayrax Waste Scouts around the signal scar, then return to the marker.",
          "conditions": [
