          "op": "write_log",
          "message": "Relay Signal Scar reached."
        },
        {
          "op": "advance_step",
          "next_step": "ch4_06_signal_scar_reached"
        }
      ]
    },
    "ch4_06_signal_scar_reached": {
      "objective_text": "Scan the Relay Signal Scar.",
      "target_object_id": "ch4_signal_scar_beacon_001",
      "target_owner_type": "beacon",
      "interaction_type": "access",
      "interaction_range": 140,
      "next_step": "ch4_07_vayrax_waste_scout_sweep",
      "actions": [
        {
          "button_id": "scan_ch4_signal_scar",
          "label": "SCAN SCAR",
          "action_id": "event_operations",
          "range": 140,
          "operations": [
            {
              "op": "show_story_popup",
              "title": "SIGNAL SCAR",
              "text": "[b]AMI SCAN[/b]\n\nThe carrier scar is not empty. It is lined with retrieval marks.\n\nAMI: Three Vayrax contacts are sweeping the fold residue. They are not guarding territory. They are collecting usable remains.\n\nTOM: Collecting what?\n\nAMI: Everything.",
              "close_mode": "button",
              "popup_size": {
                "x": 620,
                "y": 470
              }
            },
            {
              "op": "advance_step",
              "next_step": "ch4_07_vayrax_waste_scout_sweep"
            }
          ]
        }
      ]
    },
    "ch4_07_vayrax_waste_scout_sweep": {
      "objective_text": "Defeat three Vayrax Waste Scouts around the signal scar, then confirm the sweep at the scar marker.",
      "target_object_id": "ch4_signal_scar_beacon_001",
      "target_owner_type": "beacon",
      "interaction_type": "hunt",
      "interaction_range": 180,
      "next_step": "ch4_08_scout_sweep_clear",
      "on_enter": [
        {
          "op": "install_event_object",
          "target_object_id": "ch4_vayrax_waste_scout_001"
        },
        {
          "op": "install_event_object",
