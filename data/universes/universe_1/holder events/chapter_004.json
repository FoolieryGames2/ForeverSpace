  "steps": {
    "ch4_01_habitat_aftershock": {
      "objective_text": "Chapter 004 begins at the Human Station Habitat after the relay crisis.",
      "target_object_id": "human_station_habitat_beacon_001",
      "target_owner_type": "beacon",
      "interaction_type": "story_popup",
      "next_step": "ch4_02_refresh_habitat_contacts",
      "on_enter": [
        {
          "op": "write_log",
          "message": "Chapter 004 started from the Chapter 003 habitat listener."
        },
        {
          "op": "show_story_popup",
          "title": "CHAPTER 004: SIGNAL AFTERSHOCK",
          "text": "[b]HUMAN STATION HABITAT[/b]\n\nThe relay is quiet.\n\nFor one breath, the habitat believes that means safety.\n\nThen every passive antenna on the hull wakes at once.\n\nAMI: Residual carrier noise detected.\n\nMELISSA: That is not residual. Something answered.",
          "close_mode": "button",
          "popup_size": {
            "x": 640,
            "y": 500
          },
          "next_step_on_close": "ch4_02_refresh_habitat_contacts",
          "images": [
            {
              "path": "res://images/Melissa.png"
            }
          ],
          "image_height": 140
        }
      ]
    },
    "ch4_02_refresh_habitat_contacts": {
      "objective_text": "Habitat contacts are refreshing for the wider-space crisis briefing.",
      "target_object_id": "human_station_habitat_beacon_001",
      "interaction_type": "story_popup",
      "next_step": "ch4_03_melissa_signal_fragment",
      "on_enter": [
        {
          "op": "refresh_npc",
          "target_object_id": "melissa_nudawn_001",
          "replacement_object_id": "melissa_nudawn_001",
          "force_recreate": true,
          "store_event_object": true,
          "save_world": true
        },
        {
          "op": "refresh_npc",
          "target_object_id": "hank_marshall_001",
          "replacement_object_id": "hank_marshall_001",
          "force_recreate": true,
          "store_event_object": true,
          "save_world": true
        },
        {
          "op": "refresh_npc",
          "target_object_id": "roino",
          "replacement_object_id": "roino",
          "force_recreate": true,
          "store_event_object": true,
          "save_world": true
        },
        {
          "op": "refresh_npc",
          "target_object_id": "bill",
          "replacement_object_id": "bill",
          "force_recreate": true,
          "store_event_object": true,
          "save_world": true
        },
        {
          "op": "refresh_npc",
          "target_object_id": "fred",
          "replacement_object_id": "fred",
          "force_recreate": true,
          "store_event_object": true,
          "save_world": true
        },
        {
          "op": "write_log",
          "message": "Chapter 004 habitat NPC context refreshed: Melissa, Hank, Roino, Bill, Fred."
        },
        {
          "op": "show_story_popup",
          "title": "HABITAT AWAKE",
          "text": "[b]STATION STATUS[/b]\n\nMelissa pulls signal fragments into a working map. Hank opens every emergency channel he swore he would never use. Roino brings the repair dock hot. Bill and Fred stop pretending this is normal.\n\nThe habitat is no longer waiting for the next hit.\n\nIt is preparing for one.",
          "close_mode": "button",
          "popup_size": {
            "x": 620,
            "y": 470
          },
          "next_step_on_close": "ch4_03_melissa_signal_fragment",
          "images": [
            {
              "path": "res://images/Melissa.png"
            }
          ],
          "image_height": 140
        }
      ]
    },
    "ch4_03_melissa_signal_fragment": {
      "objective_text": "Take Melissa's wider-space signal briefing.",
      "target_object_id": "melissa_nudawn_001",
      "target_owner_type": "npc",
      "interaction_type": "link_call",
      "interaction_range": 220,
      "next_step": "ch4_04_hank_opens_the_map",
      "actions": [
        {
          "button_id": "take_melissa_ch4_briefing",
          "label": "TAKE BRIEFING",
          "action_id": "event_operations",
          "range": 220,
          "operations": [
            {
              "op": "show_story_popup",
              "title": "MELISSA: SIGNAL FRAGMENT",
              "text": "[b]MELISSA[/b]\n\n\"The relay was not the source. It was a pipe.\"\n\n\"You cut the pipe, but a piece of the signal escaped before the seal.\"\n\n\"It did not scream for an army. Not yet. It called something smaller and meaner. A collection unit. A warden.\"\n\n\"There is a scar in local space where the carrier folded. Go there first. Find what answered.\"",
              "close_mode": "button",
              "popup_size": {
                "x": 640,
                "y": 500
              },
              "images": [
                {
                  "path": "res://images/Melissa.png"
                }
              ],
              "image_height": 140
            },
            {
              "op": "advance_step",
              "next_step": "ch4_04_hank_opens_the_map"
            }
          ]
        }
      ]
    },
    "ch4_04_hank_opens_the_map": {
      "objective_text": "Hank opens a wider route target for the signal scar.",
      "target_object_id": "human_station_habitat_beacon_001",
      "interaction_type": "story_popup",
      "next_step": "ch4_05_travel_to_signal_scar",
      "on_enter": [
        {
          "op": "install_event_object",
          "target_object_id": "ch4_signal_scar_beacon_001"
        },
        {
          "op": "show_story_popup",
          "title": "HANK: WIDER ROUTE",
          "text": "[b]HANK[/b]\n\n\"I pushed a wider nav pocket into your route table.\"\n\n\"Do not thank me. I hate doing this.\"\n\n\"But if Melissa is right, hiding at the habitat just lets the Vayrax pick the hour.\"\n\n\"Auto Pilot has the signal scar. Go see what answered us.\"",
          "close_mode": "button",
          "popup_size": {
            "x": 620,
            "y": 470
          },
          "next_step_on_close": "ch4_05_travel_to_signal_scar",
          "images": [
            {
              "path": "res://images/Hank.png"
            }
          ],
          "image_height": 140
        },
        {
          "op": "write_log",
          "message": "Wider route opened. Relay Signal Scar installed as Chapter 004 target."
        }
      ]
    },
    "ch4_05_travel_to_signal_scar": {
      "objective_text": "Travel to the Relay Signal Scar and scan the response residue.",
      "target_object_id": "ch4_signal_scar_beacon_001",
      "target_owner_type": "beacon",
      "interaction_type": "find",
      "arrival_range": 180,
      "next_step": "ch4_06_signal_scar_reached",
      "on_arrival": [
