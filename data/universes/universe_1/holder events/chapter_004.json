    "ch4_13_bleezzee_defeated": {
      "objective_text": "Warden Bleezzee is down. Receive the recovered pattern and return to the habitat.",
      "target_object_id": "ch4_waste_nest_beacon_001",
      "interaction_type": "story_popup",
      "next_step": "ch4_14_claim_recovered_pattern",
      "on_enter": [
        {
          "op": "set_flag",
          "flag_id": "warden_bleezzee_defeated",
          "value": true
        },
        {
          "op": "show_story_popup",
          "title": "WARDEN DOWN",
          "text": "[b]WARDEN BLEEZZEE DEFEATED[/b]\n\nThe waste nest loses cohesion. Salvage tethers snap one by one.\n\nAMI: The warden carried a compressed fabrication pattern in its recovery core.\n\nTOM: It was going to use that on us?\n\nAMI: On what remained of us.\n\nTOM: Then we use it first.",
          "close_mode": "button",
          "popup_size": {
            "x": 620,
