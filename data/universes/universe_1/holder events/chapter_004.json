    "ch4_11_ready_for_bleezzee": {
      "objective_text": "Prepare your loadout, then press READY near the Warden Waste Nest to engage Bleezzee.",
      "target_object_id": "ch4_waste_nest_beacon_001",
      "target_owner_type": "beacon",
      "interaction_type": "handoff",
      "interaction_range": 220,
      "next_step": "ch4_12_battle_warden_bleezzee",
      "on_enter": [
        {
          "op": "show_story_popup",
          "title": "BOSS WARNING",
          "text": "[b]AMI[/b]\n\nWarden Bleezzee is not a standard drone.\n\nHeavy mass. Repair behavior likely. Salvage-pattern targeting. It may prioritize disabling systems it can reclaim.\n\nOpen Loadout before engaging. Bring repair and shield support if available.",
          "close_mode": "button",
          "popup_size": {
            "x": 600,
