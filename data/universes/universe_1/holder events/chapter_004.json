    "ch4_08_scout_sweep_clear": {
      "objective_text": "The scout sweep is clear. Analyze the heavy Vayrax response signature.",
      "target_object_id": "ch4_signal_scar_beacon_001",
      "interaction_type": "story_popup",
      "next_step": "ch4_09_bleezzee_first_call",
      "on_enter": [
        {
          "op": "show_story_popup",
          "title": "SCOUT SWEEP CLEAR",
          "text": "[b]AMI CHECK[/b]\n\nVayrax Waste Scout contacts: three defeated.\n\nThe scan residue begins resolving into a command identity. It is not a drone serial. It is a name carried like a rank.\n\nAMI: Warden classification detected. Heavy body. Waste-harvester authority.\n\nName translation: Bleezzee.",
          "close_mode": "button",
          "popup_size": {
            "x": 620,
            "y": 470
          },
          "next_step_on_close": "ch4_09_bleezzee_first_call"
        }
      ]
    },
    "ch4_09_bleezzee_first_call": {
      "objective_text": "Warden Bleezzee has answered the broken signal.",
      "interaction_type": "story_popup",
      "next_step": "ch4_10_travel_to_waste_nest",
      "on_enter": [
        {
          "op": "install_event_object",
          "target_object_id": "ch4_waste_nest_beacon_001"
        },
        {
          "op": "show_story_popup",
          "title": "WARDEN BLEEZZEE",
          "text": "[b]VAYRAX TRANSMISSION[/b]\n\nA wet, grinding voice pushes through the scar. It sounds too large for the channel.\n\n\"I will find what remains of you.\"\n\n\"I let nothing go to waste.\"\n\nAMI: Warden Bleezzee has locked a nest coordinate to our return path.\n\nTOM: Then we do not bring that thing back to the habitat.",
          "close_mode": "button",
          "popup_size": {
            "x": 640,
            "y": 500
          },
          "next_step_on_close": "ch4_10_travel_to_waste_nest"
        },
        {
          "op": "write_log",
          "message": "Warden Bleezzee identified. Waste Nest target installed."
        }
      ]
    },
    "ch4_10_travel_to_waste_nest": {
      "objective_text": "Travel to the Warden Waste Nest before Bleezzee tracks the habitat route.",
      "target_object_id": "ch4_waste_nest_beacon_001",
