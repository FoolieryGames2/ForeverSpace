  "steps": {
    "moonpie_01_distress_call": {
      "objective_text": "A faint distress signal breaks through local static.",
      "interaction_type": "story_popup",
      "next_step": "moonpie_02_travel_to_signal",
      "on_enter": [
        {
          "op": "install_event_object",
          "target_object_id": "moonpie_damaged_saucer_001"
        },
        {
          "op": "write_log",
          "message": "MoonPie distress call detected."
        },
        {
          "op": "show_story_popup",
          "title": "DISTRESS CALL",
          "text": "[b]DISTRESS CALL[/b]\n\nThe signal is faint, broken, but definitely there.\n\nAMI: The source is too small to be a normal ship. Signal damage is heavy. It may be bait.\n\nTOM: Or it may need help.\n\nAMI: That is the dangerous interpretation.\n\nTOM: Then we investigate carefully.",
          "close_mode": "button",
          "position": {
            "x": -350,
            "y": 0
          },
          "popup_size": {
            "x": 580,
            "y": 430
          },
          "next_step_on_close": "moonpie_02_travel_to_signal",
          "images": [
            {
              "path": "res://images/Moonpie_first_look.png"
            }
          ],
          "image_height": 150
        }
      ]
    },
    "moonpie_02_travel_to_signal": {
      "objective_text": "Travel to the tiny damaged signal source.",
      "target_object_id": "moonpie_damaged_saucer_001",
      "interaction_type": "find",
      "arrival_range": 150,
      "next_step": "moonpie_03_inspect_damaged_unit",
      "on_arrival": [
        {
          "op": "write_log",
          "message": "Damaged saucer unit reached."
        },
        {
          "op": "advance_step",
          "next_step": "moonpie_03_inspect_damaged_unit"
        }
      ]
    },
    "moonpie_03_inspect_damaged_unit": {
      "objective_text": "Inspect the damaged saucer-shaped unit.",
      "target_object_id": "moonpie_damaged_saucer_001",
      "interaction_type": "inspect",
      "interaction_range": 120,
      "next_step": "moonpie_04_repair_unit",
      "actions": [
        {
          "button_id": "inspect_moonpie_damaged_unit",
          "label": "INSPECT UNIT",
          "action_id": "event_operations",
          "range": 120,
          "operations": [
            {
              "op": "show_story_popup",
              "title": "DAMAGED SAUCER UNIT",
              "text": "[b]AMI SCAN[/b]\n\nNot human. Not Vayrax. Not inert either.\n\nThe object is roughly three feet across. Its hull is smooth except for one violent breach, like something bit a chunk from the rim.\n\nManeuvering system: disabled.\nPower: intermittent.\nInternal repair lattice: dormant.\n\nAMI: It cannot travel under its own power.",
              "close_mode": "button",
              "position": {
                "x": -350,
                "y": 0
              },
              "popup_size": {
                "x": 580,
                "y": 430
              },
              "images": [
                {
                  "path": "res://images/Moonpie_first_look.png"
                }
              ],
              "image_height": 150
            },
            {
              "op": "write_log",
              "message": "MoonPie damaged unit inspected."
            },
            {
              "op": "advance_step",
              "next_step": "moonpie_04_repair_unit"
            }
          ]
        }
      ]
    },
    "moonpie_04_repair_unit": {
      "objective_text": "Use one Repair Kit to stabilize the damaged saucer unit.",
      "target_object_id": "moonpie_damaged_saucer_001",
      "interaction_type": "handoff",
      "interaction_range": 90,
      "requires_item": "repair_kit",
      "gives_item": "moonpie_damaged_guardian_unit",
      "next_step": "moonpie_05_cargo_hold_decode",
      "actions": [
        {
          "button_id": "use_repair_kit_on_moonpie",
          "label": "USE REPAIR KIT",
          "action_id": "download_beacon_data",
          "range": 90
        }
      ]
    },
    "moonpie_05_cargo_hold_decode": {
      "objective_text": "AMI decodes broken guardian data from the unit in cargo.",
      "interaction_type": "story_popup",
      "next_step": "moonpie_06_name_moonpie",
      "on_enter": [
        {
          "op": "show_story_popup",
          "title": "CARGO HOLD DECODE",
          "text": "[b]CARGO HOLD[/b]\n\nThe small saucer sits in the cargo bay, humming like a wounded tool trying to remember its purpose.\n\nAMI: Internal auto-repair has activated. Communication remains damaged. I can decode fragments only.\n\nguardian...\nsite...\nbuilders silent...\nvault broken...\nVayrax extraction...\ndefense failed...\nrelics removed...\nhome marker follows...",
          "close_mode": "button",
          "position": {
            "x": -340,
            "y": 0
          },
          "popup_size": {
            "x": 600,
            "y": 450
          },
          "next_step_on_close": "moonpie_06_name_moonpie",
          "images": [
            {
              "path": "res://images/Moonpie.png"
            }
          ],
          "image_height": 150
        }
      ]
    },
    "moonpie_06_name_moonpie": {
      "objective_text": "Tom gives the damaged guardian unit a nickname.",
      "interaction_type": "story_popup",
      "next_step": "moonpie_07_decode_home_location",
      "on_enter": [
        {
          "op": "show_story_popup",
          "title": "MOONPIE",
          "text": "TOM: You are round, stubborn, and somehow still alive.\n\nAMI: That is not a classification.\n\nTOM: MoonPie it is.\n\nAMI: I will log the guardian unit under your informal designation. Against my better judgment.",
          "close_mode": "button",
          "position": {
            "x": -350,
            "y": 0
          },
          "popup_size": {
            "x": 580,
            "y": 430
          },
          "next_step_on_close": "moonpie_07_decode_home_location",
          "images": [
            {
              "path": "res://images/Moonpie.png"
            }
          ],
          "image_height": 150
        },
        {
          "op": "write_log",
          "message": "Tom nicknamed the damaged guardian unit MoonPie."
        }
      ]
    },
    "moonpie_07_decode_home_location": {
      "objective_text": "Decode MoonPie\u2019s damaged home-location packet.",
      "interaction_type": "story_popup",
      "next_step": "moonpie_08_travel_to_ancient_site",
      "on_enter": [
        {
          "op": "install_event_object",
          "target_object_id": "moonpie_ancient_site_001"
        },
        {
          "op": "show_story_popup",
          "title": "HOME MARKER",
          "text": "AMI: The location packet is damaged, but the emotional weighting is unusually strong.\n\nTOM: Emotional weighting?\n\nAMI: Closest translation: home.\n\nMoonPie is pointing us toward an old site. The packet also repeats a Vayrax extraction warning.",
