# ==========================================================

build/
builds/
export/
exports/
dist/
release/
release_builds/

*.pck
*.apk
*.aab
*.app
*.dmg
*.msi


# Ignore exported Windows executables, but allow project tools
# to be explicitly restored later using !filename.exe if needed.
*.exe


