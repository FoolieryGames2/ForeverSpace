# ==========================================================
# GODOT GENERATED FILES
# ==========================================================

.godot/
.import/

# Generated translation data
*.translation


# ==========================================================
# GODOT EXPORT CREDENTIALS / SECRETS
# ==========================================================

export_credentials.cfg
.godot/export_credentials.cfg

.env
.env.*
*.key
*.keystore


# ==========================================================
# LOCAL AI MODEL AND BUNDLED RUNTIME
# These should be distributed separately or in game releases.
# ==========================================================

local_ai/*.gguf
local_ai/runtime/

# Optional local AI logs and generated data
local_ai/logs/
local_ai/cache/
local_ai/temp/


# ==========================================================
# GODOT EDITOR EXECUTABLES
# ==========================================================

Godot_*.exe
Godot_*.console.exe


# ==========================================================
